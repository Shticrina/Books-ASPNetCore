@page "/books/{Id:int}"

@using Shared.DTOs.Books
@using Client.Interfaces.Api
@using Client.Services.UI
@using Client.Models

@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IBookApiService BookService
@inject DialogService DialogService
@inject ToastService Toast

<PageHeader Title="Book details">
    <Button Style="ButtonStyle.Default"
             Href="/books">
        Back to list
    </Button>

    <Button Style="ButtonStyle.Primary"
            Href="@($"/books/edit/{Id}")">
        Edit
    </Button>

    <Button Style="ButtonStyle.Danger"
            OnClick="DeleteBook">
        Delete
    </Button>
</PageHeader>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (book is null)
{
    <p>Book not found.</p>
}
else
{
    <Card Title="@book.Title">
        <p><strong>ISBN:</strong> @book.Isbn</p>

        <p><strong>Published:</strong> @book.PublishedYear</p>

        <p><strong>Author:</strong> @book.Author.Name</p>

        <p><strong>Category:</strong> @book.Category.Name</p>
    </Card>
}

@code{
    [Parameter]
    public int Id { get; set; }

    private BookDetailsDto? book;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        book = await BookService.GetBookByIdAsync(Id);
        isLoading = false;
    }

    private async Task DeleteBook()
    {
        var confirmed = await DialogService.ConfirmAsync(
            new DialogOptions
            {
                Title = "Delete book",
                Message = "Are you sure you want to delete this book?",
                ConfirmText = "Delete",
                ConfirmStyle = ButtonStyle.Danger
            });

        if (!confirmed)
            return;

        try
        {
            await BookService.DeleteBookAsync(Id);

            await Toast.Success("Book deleted successfully.");

            Navigation.NavigateTo("/books");
        }
        catch (Exception ex)
        {
            await Toast.Error(ex.Message);
        }
    }
}