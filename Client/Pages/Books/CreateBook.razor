@page "/books/create"

@using Client.Exceptions
@using Client.Interfaces
@using Shared.DTOs.Authors
@using Shared.DTOs.Books
@using Shared.DTOs.Categories

@inject IBookApiService BookService
@inject IAuthorApiService AuthorService
@inject ICategoryApiService CategoryService
@inject NavigationManager Navigation
@inject ToastService Toast

<PageHeader Title="Create Book">
    <Button Style="ButtonStyle.Default"
            Href="/books">
        Back to list
    </Button>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (editContext is null)
{
    <LoadingSpinner />
}
else
{
    <EditForm EditContext="editContext" OnSubmit="HandleSubmit">
        <div class="mb-3">
            <label class="form-label">Title</label>
            <InputText class="form-control"
                       @bind-Value="model.Title" />
            <ValidationMessage For="@(() => model.Title)" />
        </div>

        <div class="mb-3">
            <label class="form-label">ISBN</label>
            <InputText class="form-control"
                       @bind-Value="model.Isbn" />
            <ValidationMessage For="@(() => model.Isbn)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Published Year</label>
            <InputNumber class="form-control"
                         @bind-Value="model.PublishedYear" />
            <ValidationMessage For="@(() => model.PublishedYear)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Author</label>
            <InputSelect class="form-select"
                         @bind-Value="model.AuthorId">
                <option value="0">Select an author</option>

                @foreach (var author in authors)
                {
                    <option value="@author.Id">@author.Name</option>
                }
            </InputSelect>

            <ValidationMessage For="@(() => model.AuthorId)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>

            <InputSelect class="form-select"
                         @bind-Value="model.CategoryId">

                <option value="0">Select a category</option>

                @foreach (var category in categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </InputSelect>

            <ValidationMessage For="@(() => model.CategoryId)" />
        </div>

        <Button Style="ButtonStyle.Success">
            Create Book
        </Button>

        <Button Style="ButtonStyle.Danger"
                Href="/books">
            Cancel
        </Button>
    </EditForm>
}

@code
{
    private CreateBookDto model = new()
    {
        Title = string.Empty
    };

    private EditContext? editContext;
    private ValidationMessageStore? messageStore;

    private List<AuthorDto> authors = [];
    private List<CategoryDto> categories = [];

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(model);
        messageStore = new ValidationMessageStore(editContext);

        authors = await AuthorService.GetAuthorsAsync();
        categories = await CategoryService.GetCategoriesAsync();
    }

    private async Task HandleSubmit(EditContext context)
    {
        errorMessage = null;

        messageStore!.Clear();

        try
        {
            await BookService.CreateBookAsync(model);
            
            await Toast.Success("Book created successfully.");

            Navigation.NavigateTo("/books");
        }
        catch (ApiValidationException ex)
        {
            foreach (var error in ex.ValidationProblem.Errors)
            {
                messageStore.Add(
                    new FieldIdentifier(model, error.Key),
                    error.Value);
            }

            editContext!.NotifyValidationStateChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}