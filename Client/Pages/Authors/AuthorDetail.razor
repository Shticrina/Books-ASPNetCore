@page "/authors/{Id:int}"

@using Shared.DTOs.Authors
@using Client.Interfaces.Api
@using Client.Services.UI
@using Client.Models

@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IAuthorApiService AuthorService
@inject DialogService DialogService
@inject ToastService Toast

<PageHeader Title="Author details">
    <Button Style="ButtonStyle.Default"
             Href="/authors">
        Back to list
    </Button>

    <Button Style="ButtonStyle.Primary"
            Href="@($"/authors/edit/{Id}")">
        Edit
    </Button>

    <Button Style="ButtonStyle.Danger"
            OnClick="DeleteAuthor">
        Delete
    </Button>
</PageHeader>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (author is null)
{
    <p>Author not found.</p>
}
else
{
    <Card>
        <p><strong>Name:</strong> @author.Name</p>
        <p><strong>Bio:</strong> @author.Bio</p>
    </Card>
}

@code{
    [Parameter]
    public int Id { get; set; }

    private AuthorDetailsDto? author;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        author = await AuthorService.GetAuthorByIdAsync(Id);
        isLoading = false;
    }

    private async Task DeleteAuthor()
    {
        var confirmed = await DialogService.ConfirmAsync(
            new DialogOptions
            {
                Title = "Delete author",
                Message = "Are you sure you want to delete this author?",
                ConfirmText = "Delete",
                ConfirmStyle = ButtonStyle.Danger
            });

        if (!confirmed)
            return;

        try
        {
            await AuthorService.DeleteAuthorAsync(Id);

            await Toast.Success("Author deleted successfully.");

            Navigation.NavigateTo("/authors");
        }
        catch (Exception ex)
        {
            await Toast.Error(ex.Message);
        }
    }
}