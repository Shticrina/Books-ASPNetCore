@page "/categories"

@using Shared.DTOs.Categories
@using Client.Interfaces.Api
@using Client.Services.UI
@using Client.Models

@inject IJSRuntime JS
@inject ICategoryApiService CategoryService
@inject DialogService DialogService
@inject ToastService Toast

<PageHeader Title="Categories">
    <Button Style="ButtonStyle.Success"
             Href="/categories/create">
        Create Category
    </Button>
</PageHeader>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (categories.Count == 0)
{
    <EmptyState
        Title="No categories found"
        Message="Create your first category."
    />
}
else
{
    <Section>
        <table class="table w-full">
            <thead>
                <tr class="w-full flex justify-between">
                    <th class="w-full text-left">Name</th>
                    <th class="w-150 text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
            @foreach (var category in categories)
            {
                <tr class="w-full flex justify-between">
                    <td class="w-full text-left">@category.Name</td>

                    <td class="w-150 text-right">
                        <Button Style="ButtonStyle.Default"
                                Href="@($"/categories/{category.Id}")">
                            Details
                        </Button>
                        <Button Style="ButtonStyle.Primary"
                                Href="@($"/categories/edit/{category.Id}")">
                            Edit
                        </Button>
                        <Button Style="ButtonStyle.Danger"
                                OnClick="() => DeleteCategory(category.Id)">
                            Delete
                        </Button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </Section>
}

@code
{
    private List<CategoryDto> categories = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetCategoriesAsync();
        isLoading = false;
    }

    private async Task DeleteCategory(int id)
    {
        var confirmed = await DialogService.ConfirmAsync(
    new DialogOptions
            {
                Title = "Delete category",
                Message = "Are you sure you want to delete this category?",
                ConfirmText = "Delete",
                ConfirmStyle = ButtonStyle.Danger
            });

        if (!confirmed)
            return;

        try
        {
            await CategoryService.DeleteCategoryAsync(id);
            categories.RemoveAll(c => c.Id == id);
            await Toast.Success("Category deleted successfully.");
        }
        catch (Exception ex)
        {
            await Toast.Error(ex.Message);
        }
    }
}