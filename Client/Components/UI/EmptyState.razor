<div class="hero bg-base-200 rounded-xl">
    <div class="hero-content text-center">
        <div>
            <h2 class="text-2xl font-bold">
                @Title
            </h2>

            <p class="py-2">
                @Message
            </p>
        </div>
    </div>
</div>

@code{
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Message { get; set; } = "";
}