@using Client.Models
@using Client.Services.UI
@inject DialogService DialogService

@implements IDisposable

<Dialog
    Visible="@visible"
    Options="@options"
    OnResult="HandleResult" />

@code
{
    private bool visible;
    private DialogOptions options = new();

    private TaskCompletionSource<bool>? completionSource;

    protected override void OnInitialized()
    {
        DialogService.OnConfirm += ShowDialog;
    }

    private Task<bool> ShowDialog(DialogOptions dialogOptions)
    {
        options = dialogOptions;

        visible = true;

        completionSource = new TaskCompletionSource<bool>();

        InvokeAsync(StateHasChanged);

        return completionSource.Task;
    }

    private Task HandleResult(bool confirmed)
    {
        visible = false;

        completionSource?.SetResult(confirmed);

        StateHasChanged();

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        DialogService.OnConfirm -= ShowDialog;
    }
}