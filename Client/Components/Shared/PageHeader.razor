<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>@Title</h3>

    @if (ChildContent is not null)
    {
        @ChildContent
    }
</div>

<hr />

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}